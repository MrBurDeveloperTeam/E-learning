# Single local env file for the workspace root.
# The Vite app at the repo root reads its `VITE_*` variables from here.

# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://127.0.0.1:8787
VITE_API_BASE_URL=http://localhost:8788

# API (Cloudflare Worker / Pages Functions)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
YOUTUBE_API_KEY=your-youtube-api-key
GEMINI_API_KEY=your-gemini-api-key
STRIPE_SECRET_KEY=sk_test_...
RESEND_API_KEY=re_...

# Odoo integration
ODOO_BASE=https://mrbur.odoo.com
ODOO_DB=aht-systemadmin-mrbur-main-20994444
ODOO_SSO_API_KEY=your-odoo-sso-api-key
